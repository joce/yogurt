{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "useGitignore": true,
  "ignorePaths": [
    ".git",
    ".gitignore",
    ".pytest_cache",
    ".ruff_cache",
    ".tox",
    ".uv-cache",
    ".venv",
    "cspell.json",
    "htmlcov",
    "Makefile",
    "node_modules",
    "pyproject.toml",
    "tox.ini",
    "uv.lock"
  ],
  "files": [
    "**/*.{md,py,toml,json,yml,yaml,ps1}"
  ],
  "dictionaries": ["python"],
  "ignoreWords" :[
    "adjclose",
    "allnull",
    "avgdailyvol",
    "badvol",
    "bareword",
    "barewords",
    "capitalexpenditure",
    "cashandequivalents",
    "catchable",
    "companyshortname",
    "currentratio",
    "dayvolume",
    "dividendyield",
    "ebit",
    "ebitdamargin",
    "emptynoq",
    "eodprice",
    "eodvolume",
    "epsactual",
    "epsestimate",
    "epsgrowth",
    "epssurprisepct",
    "fiftytwowkhigh",
    "fiftytwowklow",
    "fiftytwowkpercentchange",
    "fundprofile",
    "getcrumb",
    "haspriceanomaly",
    "intradaymarketcap",
    "intradayprice",
    "intradaypricechange",
    "lastclosemarketcap",
    "lastclosepriceearnings",
    "lastclosetevebit",
    "lastclosetevebitda",
    "lasttwelvemonths",
    "markettime",
    "midcap",
    "mutualfund",
    "noadj",
    "operatingincome",
    "pegratio",
    "peratio",
    "percentchange",
    "posargs",
    "privatecompany",
    "quarterlyrevenuegrowth",
    "quickratio",
    "quotesummary",
    "quotetype",
    "recommendationsbysymbol",
    "returnonassets",
    "returnonequity",
    "sparkline",
    "startdatetime",
    "testpaths",
    "timeseriesfields",
    "totalassets",
    "totalcommonsharesoutstanding",
    "totaldebt",
    "totaldebtequity",
    "totalequity",
    "tradingcentral",
    "transactiondate",
    "unwritable",
    "VOLATALITY",
  ],
  "words": [
    "apng",
    "btwn",
    "capsys",
    "EBITDA",
    "ETFS",
    "EURUSD",
    "financials",
    "forex",
    "gaap",
    "gcrumb",
    "guce",
    "gucs",
    "jocelynlegault",
    "Legault",
    "Mergern",
    "OHLCV",
    "paywalled",
    "pnote",
    "Quartr",
    "referer",
    "triggerable",
    "tsrc",
    "unrequested",
  ],
  "patterns": [
    {
      "name": "quote_symbol",
      "pattern": "/(?:%5E|\\b)[A-Z]{2,5}(?:,[A-Z]{2,5})*\\b/"
    }
  ],
  "ignoreRegExpList": ["quote_symbol"]
}
